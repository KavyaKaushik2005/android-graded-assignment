<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/ripple_circle"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            app:tint="@color/accent_purple"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="VIDEO PLAYER"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.2"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- Player View -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/black"
        app:strokeColor="@color/accent_purple"
        app:strokeWidth="1dp"
        android:layout_marginBottom="20dp">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No Video Loaded"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- URL Input Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etUrl"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/input_background"
            android:hint="Paste video URL here..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:inputType="textUri"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btnOpenUrl"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="STREAM"
            android:backgroundTint="@color/accent_purple"
            android:textColor="@color/white"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <!-- Main Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnRestart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↺"
            android:textSize="20sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/accent_purple"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnPlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:src="@android:drawable/ic_media_play"
            app:backgroundTint="@color/accent_purple"
            app:tint="@color/white"
            app:fabSize="mini"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnPause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:src="@android:drawable/ic_media_pause"
            app:backgroundTint="@color/bg_card"
            app:tint="@color/accent_purple"
            app:fabSize="mini"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="■"
            android:textSize="20sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/accent_pink"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- File Picker -->
    <Button
        android:id="@+id/btnPickVideo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="OPEN VIDEO FILE"
        android:textColor="@color/white"
        android:backgroundTint="@color/bg_card"
        app:strokeColor="@color/accent_purple"
        app:strokeWidth="1dp"
        app:cornerRadius="28dp"/>

</LinearLayout>
