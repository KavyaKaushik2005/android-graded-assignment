<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/windowBackground">

    <!-- ══ HEADER ══ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- Title stack -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXCHANGE"
                android:textColor="@color/textSecondary"
                android:textSize="9sp"
                android:letterSpacing="0.25"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Currency"
                android:textColor="@color/textPrimary"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Settings icon button -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_currency_chip"
            android:src="@drawable/ic_settings"
            android:padding="10dp"
            android:scaleType="fitCenter"/>
    </RelativeLayout>

    <!-- ══ CONVERTER AREA ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Main converter card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_converter_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- FROM label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FROM"
                android:textColor="@color/textSecondary"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"/>

            <!-- FROM card (gold border) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_from_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <!-- Spinner + label row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <Spinner
                        android:id="@+id/spinnerFrom"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:minWidth="90dp"
                        android:background="@drawable/bg_currency_chip"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:popupBackground="@color/cardBackground"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="amount"
                        android:textColor="@color/textSecondary"
                        android:textSize="11sp"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Amount input -->
                <EditText
                    android:id="@+id/etSpinnerInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:gravity="start"
                    android:hint="0"
                    android:textColorHint="@color/cardBorder"
                    android:textColor="@color/textPrimary"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:inputType="numberDecimal"
                    android:focusable="false"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"/>
            </LinearLayout>

            <!-- SWAP divider row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/cardBorder"
                    android:layout_centerVertical="true"/>

                <Button
                    android:id="@+id/btnSwap"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerInParent="true"
                    android:background="@drawable/bg_swap_btn"
                    android:backgroundTint="@null"
                    app:backgroundTint="@null"
                    android:text="⇅"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>
            </RelativeLayout>

            <!-- TO label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TO"
                android:textColor="@color/textSecondary"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"/>

            <!-- TO card (neutral border) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_to_card"
                android:padding="14dp">

                <!-- Spinner + label row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <Spinner
                        android:id="@+id/spinnerTo"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:minWidth="90dp"
                        android:background="@drawable/bg_currency_chip"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:popupBackground="@color/cardBackground"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="result"
                        android:textColor="@color/textSecondary"
                        android:textSize="11sp"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Result value (gold) -->
                <TextView
                    android:id="@+id/tvSpinnerResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/textGold"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:paddingTop="0dp"
                    android:paddingBottom="2dp"/>

                <!-- Rate hint -->
                <TextView
                    android:id="@+id/tvRateHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 INR = 0.0120 USD"
                    android:textColor="@color/textSecondary"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ══ KEYPAD ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <!-- Row: C  ⌫ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_key_gray"
                    android:backgroundTint="@null"
                    android:text="C"
                    android:textColor="@color/textGold"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnBackspace"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_key_gray"
                    android:backgroundTint="@null"
                    android:text="⌫"
                    android:textColor="@color/keyGrayText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Row: 7  8  9 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btn7"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="7"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btn8"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="8"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btn9"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="9"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Row: 4  5  6 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btn4"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="4"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btn5"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="5"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btn6"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="6"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Row: 1  2  3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btn1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="1"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btn2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="2"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btn3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="3"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Row: 0 (wide)  . -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn0"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="0"
                    android:textColor="@color/keyDarkText"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnDot"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_key_dark"
                    android:backgroundTint="@null"
                    android:text="."
                    android:textColor="@color/keyDarkText"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>